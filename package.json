{
  "name": "ticket-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:migrate": "node dist/db/migrate.js",
    "worker:deploy": "npx wrangler deploy --config cloudflare-worker/wrangler.jsonc"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.9.0",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.5.0",
    "pg": "^8.16.3",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
