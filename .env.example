# Cloudflare Worker owns LINE, D1, subscriptions, and notification decisions.
CLOUDFLARE_WORKER_URL=https://ticket-monitor.hsiehmin.com
WORKER_API_TOKEN=

# Polling is performed by this local monitor. Do not set below 10 seconds.
POLL_INTERVAL_SECONDS=15

# Required for a background systemd service without a graphical display.
PLAYWRIGHT_HEADLESS=true
