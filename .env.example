# Cloudflare Worker owns LINE, D1, subscriptions, and notification decisions.
CLOUDFLARE_WORKER_URL=https://ticket-monitor.hsiehmin.com
WORKER_API_TOKEN=

# Polling is performed by this Windows monitor. Do not set below 120 seconds.
POLL_INTERVAL_SECONDS=180

# Tixcraft currently exposes its public session table to a visible browser.
# Keep false on Windows. Headless mode is diagnostic only.
PLAYWRIGHT_HEADLESS=false
